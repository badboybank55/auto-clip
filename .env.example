# ─── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Background video (ถ้าไม่ตั้งค่าจะใช้สีพื้นหลัง) ────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here
# สมัครฟรี: https://www.pexels.com/api/

# ─── TTS คุณภาพสูง (ไม่บังคับ — ถ้าไม่ตั้งใช้ gTTS ฟรีแทน) ─────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# สมัครฟรี 10,000 chars/เดือน: https://elevenlabs.io

# ─── Social Media Upload (ไม่บังคับ) ─────────────────────────────────────────
YOUTUBE_CLIENT_SECRET=config/client_secret.json
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
